# PhysioFlow Environment Variables

# Server Port (default: 3001)
PORT=3001

# SMS77.de API Key (get from https://www.sms77.de/)
# Leave empty to simulate SMS sending
SMS77_API_KEY=

# Allowed origin for CORS/CSRF checks in production
PHYSIOFLOW_ORIGIN=https://physio-flow.online

# Required when NODE_ENV=production, e.g. in Docker/runtime env
SESSION_SECRET=change-me-to-a-long-random-secret

# Admin password (bcrypt hash recommended; plain text is supported only for legacy fallback)
# To generate a hash: npx tsx server/db/seed-admin.ts admin yourpassword
PHYSIOFLOW_PASSWORD=change-me

# Do not put NODE_ENV in this project .env file.
# Vite reads .env during production builds and warns when NODE_ENV=production is set here.
# Set NODE_ENV=production only in the runtime environment, for example docker/physioflow/app.env.
